# backend/.env.example
# [Infrastructure - Hazelcast]
USE_LOCAL_HZ=true
HZ_CLUSTER_NAME=dev

# IMPORTANT: 
# For Docker execution: HZ_ADDRESS=hazelcast:5701
# For Local node execution: HZ_ADDRESS=localhost:5701
HZ_ADDRESS=hazelcast:5701

# [Server Configuration]
PORT=3000
NODE_ENV=development

# [Database]
# DATABASE_URL=postgresql://lex_admin:<PASSWORD>@db:5432/lex_atc
TRUST_PROXY_HOPS=0

# [Admin Auth]
ADMIN_TOKEN_SECRET=
ADMIN_AUTH_DISABLED=true
ADMIN_SOLANA_ALLOWLIST_JSON=

# [CORS]
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5180,http://127.0.0.1:5173,http://127.0.0.1:5180
CORS_ALLOW_LOCALHOST_WILDCARD=true

# [Governance]
GOVERNANCE_TIMELOCK_MS=10000
GOVERNANCE_APPROVAL_THRESHOLD=3
GOVERNANCE_APPROVAL_TOTAL=5
# GOVERNANCE_MEMBERS_JSON=[{"id":"admin1","roles":["governor","executor"]},{"id":"admin2","roles":["governor"]}]

# [Settlement]
AGENT_KEY_SEED=
TREASURY_KEY_SEED=

# [Optional: Hazelcast Cloud]
# HAZELCAST_DISCOVERY_TOKEN=
# HAZELCAST_PASSWORD=

# [AI Configuration]
USE_MOCK_AI=true
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
NEAR_AI_API_KEY=
DEFAULT_PROVIDER=mock

# [Solana Connection]
SOLANA_RPC_URL=https://api.devnet.solana.com
# 에이전트에게 초기 자금을 줄 마스터 지갑 (키페어 배열 형태나 Base58)
MASTER_WALLET_PRIVATE_KEY=

# [Mining Constitution]
# 공유 패키지의 설정을 덮어쓰고 싶을 때 사용 (선택 사항)
MINING_BASE_DIFFICULTY=1 
MINING_TARGET_TIME_SEC=5
