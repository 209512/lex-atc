# backend/.env.production.example

NODE_ENV=production
PORT=3000
TRUST_PROXY_HOPS=1

# [CORS]
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com

# [Admin Auth]
ADMIN_TOKEN_SECRET=
ADMIN_SOLANA_ALLOWLIST_JSON=

# [Contract enforcement]
CONTRACT_MODE=warn
CSRF_ENFORCE_ALL_UNSAFE=true

# [Database]
DB_MODE=pg
DATABASE_URL=

# [Hazelcast]
USE_LOCAL_HZ=false
HZ_CLUSTER_NAME=prod
HZ_ADDRESS=hazelcast:5701
HAZELCAST_DISCOVERY_TOKEN=
HAZELCAST_PASSWORD=

# [AI Configuration]
USE_MOCK_AI=false
DEFAULT_PROVIDER=openai
OPENAI_API_KEY=

# [Solana Connection]
SOLANA_RPC_URL=
MASTER_WALLET_PRIVATE_KEY=

# [Sandbox]
SANDBOX_ALLOWED_BINARIES=/bin/echo
# Per-command policy overrides (optional)
# SANDBOX_COMMAND_POLICY_JSON={"ECHO":{"requiredRoles":["executor"],"allowedClassifications":["irreversible"],"timeoutMs":1000,"auditRequired":true}}
