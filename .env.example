# ------------------------------------------
# lex-atc Environment Variables Template
# IMPORTANT: SECRETS SHOULD BE INJECTED VIA CI/CD PIPELINE (e.g. GitHub Actions, AWS Secrets Manager)
# Do not hardcode real API keys or passwords in this file.
# ------------------------------------------

NODE_ENV=development

# 1. Hazelcast Cluster Configuration
HZ_CLUSTER_NAME=dev
# Note: Set USE_LOCAL_HZ=false if running via Docker Compose to connect to the actual container.
USE_LOCAL_HZ=true
HZ_ADDRESS=hazelcast:5701

# 2. Database & Redis Configuration
REDIS_SENTINELS=redis-sentinel:26379
REDIS_SENTINEL_NAME=mymaster
# Dummy password for local development. Generate a secure password for production (e.g. openssl rand -hex 32)
REDIS_PASSWORD=change-me

# Database
POSTGRES_USER=lex_admin
# Dummy password for local development. Generate a secure password for production (e.g. openssl rand -hex 32)
POSTGRES_PASSWORD=change-me
POSTGRES_DB=lex_atc_db
# Local Docker DB connection string
DATABASE_URL=postgresql://lex_admin:change-me@db:5432/lex_atc_db

# 3. Server & Networking
PORT=3000
INIT_AGENTS=2
TRUST_PROXY_HOPS=0
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5180
CORS_ALLOW_LOCALHOST_WILDCARD=true

# Frontend (Vite)
VITE_APP_URL=http://localhost:5173
VITE_PROXY_TARGET=http://localhost:3000

# 4. Admin Auth & Governance
# Set ADMIN_AUTH_DISABLED=true only for local development/testing. Do NOT use in production.
ADMIN_TOKEN_SECRET=
ADMIN_AUTH_DISABLED=true
ADMIN_SOLANA_ALLOWLIST_JSON=

# 5. Isolation & Sandbox Engine
SANDBOX_ENGINE=mock # Options: true_wasm, mock
SANDBOX_DOCKER_IMAGE=
SANDBOX_POOL_SIZE=5
SANDBOX_EXEC_TIMEOUT_MS=5000

# 6. Web3 / Solana & Economics
AGENT_KEY_SEED=
TREASURY_KEY_SEED=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_SETTLEMENT_ENABLED=false
SOLANA_PROGRAM_ID=1exAtcSett1ementProgram11111111111111111111
SOLANA_TX_COMMITMENT=finalized
SOLANA_PRIORITY_FEE_MICRO_LAMPORTS=50000
SOLANA_ESCROW_TOKEN_ACCOUNT=
SOLANA_TREASURY_TOKEN_ACCOUNT=
SOLANA_AVG_TX_FEE_SOL=0.000005
SOLANA_USD_PRICE=150

GLOBAL_DEPOSIT_SOL=
SETTLEMENT_INTERVAL_MS=60000
SIM_ITERATION_MS=100

# 7. Irys / Arweave Archiving & Security
ENABLE_IRYS_ARCHIVING=false
IRYS_NETWORK=devnet
IRYS_PRIVATE_KEY=
DUMMY_KMS_SEED=
ALLOW_TEST_DUMMY_KEYS=false

# 8. AI Providers & ML Watcher
USE_MOCK_AI=true
DEFAULT_PROVIDER=mock
NEAR_AI_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
ML_INFERENCE_API_URL=http://localhost:8000/predict

# 9. Monitoring & Alerting
FRONTEND_URL=http://localhost:5173
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
ALERT_API_TOKEN=
LOCK_OCCUPANCY_ALERT_MS=15000
